# ============================================
# HustleUp Environment Variables
# ============================================
# NEVER commit this file to Git!
# Copy this to .env and fill in your values.
# ============================================

# Database
MYSQL_PASSWORD=francis

# JWT — Generate a strong secret: openssl rand -base64 64
JWT_SECRET=HustleUpSecretKeyForJWTTokenGenerationMustBe256BitsLongAtLeast!!2026

# File Uploads
UPLOAD_DIR=./uploads

# Stripe (subscription service only)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Frontend URL
FRONTEND_URL=http://localhost:3000
