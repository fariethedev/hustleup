# HustleUp Environment Configuration
# Copy this file to .env and fill in your values
# Then set these as environment variables before starting the backend services

# ── Database ──────────────────────────────────────────────
MYSQL_PASSWORD=your-mysql-password-here

# ── JWT Authentication ────────────────────────────────────
# Must be at least 32 characters (256 bits) for HS256
JWT_SECRET=your-jwt-secret-here-must-be-at-least-32-chars

# ── AWS S3 (optional — leave blank for local file storage) ─
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=hustle-up

# ── Stripe Payments ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── Frontend URL ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Upload Directory (default: ./uploads) ────────────────
UPLOAD_DIR=./uploads
